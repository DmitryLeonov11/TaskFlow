# ===========================================
# TaskFlow Frontend Environment Variables (Example)
# ===========================================
# Copy this file to .env and configure your values

# -------------------------------------------
# Backend API URL
# -------------------------------------------
# Browser needs localhost (api:8080 only works inside Docker network)
VITE_API_BASE_URL=http://localhost:5000/api

# -------------------------------------------
# SignalR Hub URL (for real-time updates)
# -------------------------------------------
VITE_SIGNALR_HUB_URL=http://localhost:5000/hubs
