# ===========================================
# TaskFlow Environment Variables (Example)
# ===========================================
# Copy this file to .env and configure your values

# -------------------------------------------
# Database (PostgreSQL)
# -------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=taskflow_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here

# Full connection string
CONNECTION_STRING=Host=localhost;Port=5432;Database=taskflow_db;Username=postgres;Password=your_password_here

# -------------------------------------------
# JWT Authentication
# -------------------------------------------
# IMPORTANT: Change to a secure random string (at least 32 characters)
JWT_KEY=ChangeThisToASecureSecretKeyThatIsAtLeast32CharactersLong!
JWT_ISSUER=TaskFlow
JWT_AUDIENCE=FrontendApp
JWT_EXPIRATION_MINUTES=1440

# -------------------------------------------
# Logging (Seq)
# -------------------------------------------
SEQ_SERVER_URL=http://localhost:5341

# -------------------------------------------
# Frontend URL (for CORS)
# -------------------------------------------
FRONTEND_URL=http://localhost:5173

# -------------------------------------------
# Docker Compose (for docker-compose.env)
# -------------------------------------------
VITE_API_BASE_URL=http://localhost:5000/api
VITE_SIGNALR_HUB_URL=http://localhost:5000/hubs

# Docker Compose specific (optional - for custom port mapping)
# POSTGRES_PORT=5432  # Host port for PostgreSQL container
